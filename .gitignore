# =============================================================================
# Piuma Vault — root gitignore
# =============================================================================

# ---- Dependencies / build output ----
node_modules
dist
target

# ---- Lockfiles ----
package-lock.json
bun.lock
Cargo.lock

# ---- Env & secrets ----
.env
.env*.local
keys

# ---- Mobile app (private; not part of the public repo — rebuild your own) ----
mobile/

# ---- Data / runtime (never commit DB data or dumps) ----
postgres_data
database_dumps

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- OS / editor ----
.DS_Store
.vscode/

# ---- Audio files ----
*.mp3
*.wav
*.flac
*.m4a
*.aac
*.ogg
*.wma
*.aiff
*.mid

# ---- Private docs / scripts / tooling (not for the public repo) ----
CLAUDE.md
md/
update_servers.sh
.github/full-stack.instructions.md
.codegraph/
REASONIX.md
reasonix.toml
