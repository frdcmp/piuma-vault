# =============================================================================
# Piuma Vault — root gitignore
# =============================================================================

# ---- Dependencies / build output ----
node_modules
dist
target

# ---- Lockfiles (mobile's package-lock is intentionally tracked) ----
package-lock.json
!mobile/package-lock.json
bun.lock
Cargo.lock

# ---- Env & secrets ----
.env
.env*.local
keys
mobile/google-services.json

# ---- Data / runtime (never commit DB data or dumps) ----
postgres_data
database_dumps

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- OS / editor ----
.DS_Store
.vscode/

# ---- Audio files (except the bundled in-app alarm tone) ----
*.mp3
*.wav
*.flac
*.m4a
*.aac
*.ogg
*.wma
*.aiff
*.mid
!mobile/assets/alarm.wav

# ---- Private docs / scripts / tooling (not for the public repo) ----
CLAUDE.md
md/
update_servers.sh
.github/full-stack.instructions.md
.codegraph/
REASONIX.md
reasonix.toml
