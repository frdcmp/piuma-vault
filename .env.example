# =============================================================================
# Piuma Vault — environment template
# Copy to `.env` and fill in. Every var below is actually read by the stack
# (Rust backend, embedding worker, nginx, or docker compose itself).
# =============================================================================

# ------------ Compose ------------
# Profiles: db-stack (postgres) and/or server-stack (nginx + rust + worker)
COMPOSE_PROFILES=db-stack,server-stack
COMPOSE_NAME=piuma-vault

# ------------ Server ------------
# SERVER_NAME + BASE_URL are injected into the nginx template; BASE_URL is also
# read by the Rust backend. RUST_LOG drives env_logger in both binaries.
SERVER_NAME="vault.example.com"
BASE_URL=/
RUST_LOG="info"
NGINX_PORT=8034

# CORS: comma-separated exact origins the backend will allow.
# CORS_ALLOW_LOCAL (default true) additionally permits localhost/LAN for dev;
# set it to false in production to lock down to the explicit list only.
CORS_ALLOWED_ORIGINS="https://vault.example.com,https://www.example.com"
CORS_ALLOW_LOCAL=true

# ------------ Database (PostgreSQL + pgvector) ------------
# The pool is built from these parts. DATABASE_URL (optional) overrides them.
DB_HOST=db
DB_USER=dbuser
DB_PASSWORD=changeme
DB_PORT=5432
DB_NAME=piuma_vault
DB_PORT_EXTERNAL=5489
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Boot-time schema-drift verifier (db_init's TABLES definitions vs the live DB).
# Set to 1 to enable schema-drift checks, or 0 to disable them.
DB_VERIFY_SCHEMA=1

# ------------ Email (SMTP) ------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-email-app-password

# ------------ Service config now lives in the DB ------------
# Azure embeddings (key + URL), the LLM chat providers/models, and S3 object
# storage (endpoint, region, bucket, keys, optional CDN) are configured at runtime
# in the admin Services / Agents dashboards (DB tables), NOT via env vars.

# ------------ Auth / JWT / OTP ------------
# SITE_URL is the site's canonical identity. It's used as the label shown in
# authenticator apps for 2FA (a full URL is trimmed to its host, e.g.
# "https://vault.example.com" → "vault.example.com").
SITE_URL="https://vault.example.com"

# Set to true to allow public registrations. Default is false.
ALLOW_REGISTRATION=false

# ------------ Web Push (VAPID) ------------
# Web Push (VAPID) — for browser notifications. Generate with `python3 generate_vapid.py`,
# which writes the private PEM to rust/src/keys/vapid_private.pem and prints these values.
# VAPID_PUBLIC_KEY is the base64url application server key the browser subscribes with.
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com
VAPID_PRIVATE_KEY_PATH=/app/src/keys/vapid_private.pem
# VAPID_PRIVATE_KEY_PEM=

# ------------ Mobile Build ------------
# These are read by mobile/build.sh when building and publishing your custom
# React Native / Expo companion app. They are NOT used by the backend.
# EXPO_TOKEN is required for EAS local building/publishing.
# FRDCMP_API_KEY is an API Key with `storage.access` permission to upload build artifacts.
EXPO_TOKEN=
FRDCMP_API_KEY=
