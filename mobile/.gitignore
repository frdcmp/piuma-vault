# =============================================================================
# Piuma Vault — mobile gitignore (Expo / React Native)
# =============================================================================

# ---- Dependencies ----
node_modules/

# ---- Expo / Metro / generated native folders ----
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*
/ios
/android

# ---- Env & secrets (keep .env.example tracked) ----
.env
.env*.local
google-services.json

# ---- Native signing / keys ----
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ---- Logs ----
npm-debug.*
yarn-debug.*
yarn-error.*

# ---- OS / TypeScript ----
.DS_Store
*.tsbuildinfo

# ---- Build artifacts (build.sh outputs) ----
*.apk
*.aab
