# =============================================================================
# Piuma Vault — mobile build environment template
# Copy to `.env` and fill in. Read by mobile/build.sh (EAS build + artifact
# upload); not used by the backend.
# =============================================================================

# EXPO_TOKEN: required for EAS local building/publishing.
# Get one at https://expo.dev/accounts/<your-account>/settings/access-tokens
EXPO_TOKEN=

# VAULT_API_KEY: a vault API key with `storage.access` permission, for the upload step.
VAULT_API_KEY=
