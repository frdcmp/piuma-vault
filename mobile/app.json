{
  "expo": {
    "name": "pv vault",
    "slug": "pv",
    "version": "1.0.23",
    "scheme": "piumavault",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0f12"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow Piuma Vault to use the microphone to record and transcribe.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.pv.vault",
      "googleServicesFile": "./google-services.json",
      "versionCode": 5,
      "permissions": [
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0e0f12",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "be8facbf-33d6-44e5-908a-2f68c434420f"
      }
    },
    "owner": "pv",
    "plugins": [
      "expo-video",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Piuma Vault to use the microphone to record and transcribe."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#5cd0a9"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Unlock Piuma Vault with Face ID."
        }
      ],
      "./plugins/withAndroidAlarm",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Tasks",
              "label": "Vault Tasks",
              "description": "Upcoming and overdue tasks",
              "minWidth": "180dp",
              "minHeight": "180dp",
              "targetCellWidth": 3,
              "targetCellHeight": 3,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Calendar",
              "label": "Vault Calendar",
              "description": "Upcoming events",
              "minWidth": "180dp",
              "minHeight": "180dp",
              "targetCellWidth": 3,
              "targetCellHeight": 3,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "expo-background-task",
      [
        "@siteed/audio-studio",
        {
          "enablePhoneStateHandling": true,
          "enableNotifications": true,
          "enableBackgroundAudio": true,
          "iosBackgroundModes": {
            "useAudio": true,
            "useProcessing": true
          },
          "iosConfig": {
            "microphoneUsageDescription": "Allow Piuma Vault to use the microphone to record and transcribe.",
            "backgroundProcessingTitle": "Recording in progress"
          }
        }
      ]
    ]
  }
}
